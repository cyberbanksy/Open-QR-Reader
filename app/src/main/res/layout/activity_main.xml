<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/screen_background"
    android:paddingStart="28dp"
    android:paddingTop="28dp"
    android:paddingEnd="28dp"
    android:paddingBottom="28dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/preview_container_background"
        android:clipToOutline="true"
        android:elevation="10dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/scanner_shell"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/scanner_surface_background"
            android:clipToOutline="true">

            <TextureView
                android:id="@+id/camera_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.5" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/preview_scrim_background" />

            <View
                android:id="@+id/scanner_edge_glow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.82"
                android:background="@drawable/scanner_inner_glow" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/sweep_view"
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:layout_gravity="center"
                    android:src="@drawable/scanner_sweep" />

                <View
                    android:id="@+id/pulse_ring"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/scanner_pulse_ring" />

                <ImageView
                    android:id="@+id/brackets_view"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/scanner_brackets" />

                <View
                    android:id="@+id/center_dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_gravity="center"
                    android:background="@drawable/scanner_center_dot" />

                <ImageView
                    android:id="@+id/state_icon"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_gravity="center"
                    android:background="@drawable/state_badge_background"
                    android:contentDescription="@string/logo_content_description"
                    android:padding="22dp"
                    android:visibility="gone" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/action_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/action_button_background"
            android:paddingStart="24dp"
            android:paddingTop="14dp"
            android:paddingEnd="24dp"
            android:paddingBottom="14dp"
            android:text="@string/action_scanning"
            android:textAllCaps="false"
            android:textColor="@color/action_button_text"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
