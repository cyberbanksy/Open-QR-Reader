<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/preview_container_background"
    android:clipToOutline="true"
    android:elevation="10dp"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="21sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/scanner_shell"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/scanner_surface_background"
            android:clipToOutline="true">

            <ImageView
                android:id="@+id/camera_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.5"
                android:scaleType="centerCrop" />

            <View
                android:id="@+id/preview_scrim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/preview_scrim_background" />

            <View
                android:id="@+id/scanner_edge_glow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.82"
                android:background="@drawable/scanner_inner_glow" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/sweep_view"
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:layout_gravity="center"
                    android:src="@drawable/scanner_sweep" />

                <View
                    android:id="@+id/pulse_ring"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/scanner_pulse_ring" />

                <ImageView
                    android:id="@+id/brackets_view"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/scanner_brackets" />

                <View
                    android:id="@+id/center_dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_gravity="center"
                    android:background="@drawable/scanner_center_dot" />

                <ImageView
                    android:id="@+id/state_icon"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_gravity="center"
                    android:background="@drawable/state_badge_background"
                    android:contentDescription="@string/logo_content_description"
                    android:padding="22dp"
                    android:visibility="gone" />
            </FrameLayout>
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/action_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/camera_mode_button"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/secondary_action_button_background"
            android:contentDescription="@string/action_camera_mode"
            android:padding="13dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_camera_mode"
            android:tint="@color/text_primary" />

        <Button
            android:id="@+id/action_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/action_button_background"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="22dp"
            android:paddingTop="15dp"
            android:paddingEnd="22dp"
            android:paddingBottom="15dp"
            android:text="@string/action_scanning"
            android:textAllCaps="false"
            android:textColor="@color/action_button_text"
            android:textSize="15sp" />
    </LinearLayout>
</LinearLayout>
