<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_fill_disabled" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#14FFFFFF" />
        </shape>
    </item>
    <item android:state_selected="true" android:state_hovered="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_fill_hovered" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#88B8CCE8" />
        </shape>
    </item>
    <item android:state_hovered="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_fill_hovered" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#88B8CCE8" />
        </shape>
    </item>
    <item android:state_selected="true" android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_fill_hovered" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#88B8CCE8" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_fill_hovered" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#88B8CCE8" />
        </shape>
    </item>
    <item android:state_selected="true" android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_fill_pressed" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#8098B6D9" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_fill_pressed" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#8098B6D9" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_fill" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#16FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/button_fill" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#16FFFFFF" />
        </shape>
    </item>
</selector>
