<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/secondary_button_fill_disabled" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="@color/secondary_button_stroke_disabled" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/secondary_button_fill_selected" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="@color/secondary_button_stroke_selected" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/secondary_button_fill_pressed" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="@color/secondary_button_stroke_selected" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/secondary_button_fill" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="@color/secondary_button_stroke" />
        </shape>
    </item>
</selector>
